{
  "name": "@samchon/shopping-api",
  "version": "0.18.0",
  "description": "API for shopping",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/shopping"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/shopping/issues"
  },
  "homepage": "https://github.com/samchon/shopping#readme",
  "scripts": {
    "build": "rimraf lib && ttsc && rolldown -c",
    "build:sdk": "cd ../backend && pnpm build:sdk",
    "format": "ttsc format -p tsconfig.json",
    "lint": "ttsc -p tsconfig.json --noEmit",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@nestia/fetcher": "catalog:samchon",
    "typia": "catalog:samchon",
    "uuid": "catalog:utils"
  },
  "devDependencies": {
    "@ttsc/lint": "catalog:typescript",
    "@ttsc/unplugin": "catalog:typescript",
    "rimraf": "catalog:utils",
    "rolldown": "^1.1.5",
    "tinyglobby": "^0.2.17",
    "ttsc": "catalog:typescript",
    "typescript": "catalog:typescript"
  },
  "include": [
    "lib",
    "package.json",
    "swagger.json",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "main": "./lib/index.js",
    "module": "./lib/index.mjs",
    "types": "./lib/index.d.ts",
    "exports": {
      ".": {
        "types": "./lib/index.d.ts",
        "import": "./lib/index.mjs",
        "default": "./lib/index.js"
      }
    }
  }
}
