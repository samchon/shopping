{
  "private": true,
  "name": "@samchon/shopping-backend",
  "version": "0.18.0",
  "description": "Backend for shopping",
  "scripts": {
    "test": "rimraf prisma/migrations && ts-node test",
    "benchmark:performance": "node test/benchmark/performance",
    "------------------------BUILDS------------------------": "",
    "build": "pnpm build:prisma && pnpm build:sdk && pnpm build:main",
    "build:env": "ts-node build/env.ts",
    "build:main": "rimraf lib && tsc",
    "build:prisma": "pnpm build:env && prisma generate --schema=prisma/schema",
    "build:sdk": "rimraf src/api/functional && nestia all",
    "build:swagger": "nestia swagger",
    "build:test": "tsc -p test/tsconfig.json",
    "dev": "tsc -p test/tsconfig.json --watch",
    "prepare": "ts-patch install && pnpm build:prisma && prisma db push",
    "------------------------DEPLOYS------------------------": "",
    "start": "node lib/executable/server",
    "start:ts": "ts-node src/executable/server.ts",
    "start:dev": "nest start --watch",
    "schema": "ts-node src/executable/schema"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/shopping"
  },
  "author": "AUTHOR",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/shopping/issues"
  },
  "homepage": "https://github.com/samchon/shopping",
  "devDependencies": {
    "@nestia/benchmark": "catalog:samchon",
    "@nestia/e2e": "catalog:samchon",
    "@nestjs/cli": "^11.0.16",
    "@types/bcryptjs": "^2.4.6",
    "@types/cli": "^0.11.19",
    "@types/cli-progress": "^3.11.5",
    "@types/express": "^4.17.21",
    "@types/inquirer": "^8.2.5",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^24.0.0",
    "cagen": "^1.0.1",
    "chalk": "^4.1.2",
    "cli": "^1.0.1",
    "cli-progress": "^3.12.0",
    "inquirer": "^8.2.5",
    "nestia": "catalog:samchon",
    "rimraf": "catalog:utils",
    "prisma-markdown": "^4.0.0",
    "ts-node": "catalog:typescript",
    "ts-patch": "catalog:typescript",
    "typescript": "catalog:typescript",
    "typescript-transform-paths": "catalog:typescript"
  },
  "dependencies": {
    "@nestia/core": "catalog:samchon",
    "@nestia/editor": "catalog:samchon",
    "@nestia/fetcher": "catalog:samchon",
    "@nestia/sdk": "catalog:samchon",
    "@nestjs/common": "^11.1.12",
    "@nestjs/core": "^11.1.12",
    "@nestjs/platform-fastify": "^11.1.12",
    "@prisma/adapter-better-sqlite3": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@prisma/internals": "^7.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "bcryptjs": "^2.4.3",
    "commander": "^11.1.0",
    "csv-parse": "^5.5.3",
    "dotenv": "^16.3.1",
    "dotenv-expand": "^10.0.0",
    "fastify": "^4.25.2",
    "git-last-commit": "^1.0.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.78.1",
    "prisma": "^7.3.0",
    "rollup": "^4.18.1",
    "serialize-error": "^4.1.0",
    "source-map-support": "^0.5.19",
    "tstl": "catalog:samchon",
    "typia": "catalog:samchon",
    "uuid": "catalog:utils"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
