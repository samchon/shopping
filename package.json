{
  "name": "@samchon/shopping",
  "version": "0.1.0",
  "description": "Shopping monorepo",
  "scripts": {
    "build": "pnpm -r build",
    "format": "prettier --write \"**/*.(ts|tsx)\"",
    "format:check": "prettier --check \"**/*.(ts|tsx)\"",
    "prepare": "ts-patch install",
    "start": "ts-node scripts/start.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/shopping"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/shopping/issues"
  },
  "homepage": "https://github.com/samchon/shopping#readme",
  "packageManager": "pnpm@10.10.0",
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/node": "^25.6.0",
    "prettier": "^3.3.2",
    "prettier-plugin-prisma": "^5.0.0",
    "ts-node": "catalog:typescript",
    "ts-patch": "catalog:typescript",
    "typescript": "catalog:typescript"
  }
}
