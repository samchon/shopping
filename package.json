{
  "name": "@samchon/shopping",
  "version": "0.1.0",
  "description": "Shopping monorepo",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm --filter @samchon/shopping-api lint && pnpm --filter @samchon/shopping-backend lint && pnpm --filter @samchon/shopping-frontend lint",
    "format": "pnpm --filter @samchon/shopping-api format && pnpm --filter @samchon/shopping-backend format && pnpm --filter @samchon/shopping-frontend format",
    "format:check": "pnpm lint",
    "start": "ttsx scripts/start.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/shopping"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/shopping/issues"
  },
  "homepage": "https://github.com/samchon/shopping#readme",
  "packageManager": "pnpm@10.10.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "prisma",
      "@prisma/engines",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@ttsc/lint": "catalog:typescript",
    "@types/node": "^25.6.0",
    "ttsc": "catalog:typescript",
    "typescript": "catalog:typescript"
  }
}
